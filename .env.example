# PostHog project key (public, non-secret)
# Set in GitHub repo Settings > Variables (not Secrets) for CI builds.
VITE_POSTHOG_KEY=
# PostHog API host — defaults to https://us.i.posthog.com if omitted
VITE_POSTHOG_HOST=
# Optional owner-mode distinct ID used by window.__so.enable() and ?__so=1
VITE_POSTHOG_OWNER_ID=owner:harmad
# Optional owner-mode email person property
VITE_POSTHOG_OWNER_EMAIL=harmad@harmadavtian.com

# Public base URL of the content API used by the fast experience.
# In production set this to https://api.harmadavtian.com (without trailing slash).
# If omitted at build time, the fast experience will fall back to bundled
# JSON content rather than calling http://localhost:8080 (which would trigger
# the browser's "access other apps and services on this device" prompt).
VITE_API_BASE_URL=
